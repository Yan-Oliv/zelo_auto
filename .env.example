# Preferred: point this to a small backend/serverless endpoint that returns
# an array or { "data": [...] } with Instagram media fields.
VITE_INSTAGRAM_FEED_ENDPOINT=

# Optional direct Graph API fallback for local tests. Avoid exposing long-lived
# production tokens in client-side builds; use the endpoint above in production.
VITE_INSTAGRAM_GRAPH_USER_ID=
VITE_INSTAGRAM_ACCESS_TOKEN=
